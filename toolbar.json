[
  {
    "group": "Viewer",
    "color": "info",
    "row": 1,
    "elements": [
      {
        "label": "GitHub",
        "icon": "GitHub SVG",
        "id": "btn-github",
        "onclick": "window.open('https://github.com/')"
      },
      {
        "label": "↑ Import",
        "id": "btn-import",
        "onclick": "loadFile()"
      },
      {
        "label": "↓ Export",
        "id": "btn-export",
        "onclick": "download()"
      },
      {
        "label": "↓ JSON",
        "id": "btn-json",
        "onclick": "exportJson()"
      },
      {
        "label": "↓ HTML",
        "id": "btn-html",
        "onclick": "exportHtml()"
      },
      {
        "label": "↓ PDF",
        "id": "btn-pdf",
        "onclick": "exportPdf()"
      },
      {
        "label": "↓ Image",
        "id": "btn-image",
        "onclick": "exportImage()"
      },
      {
        "label": "Copy",
        "id": "btn-copy",
        "onclick": "copyClipboard()"
      }
    ]
  },
  {
    "group": "View",
    "color": "info",
    "row": 1,
    "type": "toggle",
    "elements": [
      {
        "label": "Editor",
        "id": "btn-view-editor",
        "onclick": "setViewMode('editor')"
      },
      {
        "label": "Both",
        "id": "btn-view-both",
        "onclick": "setViewMode('both')"
      },
      {
        "label": "Preview",
        "id": "btn-view-preview",
        "onclick": "setViewMode('preview')"
      }
    ]
  },
  {
    "group": "Toggle",
    "color": "danger",
    "row": 1,
    "type": "toggle",
    "elements": [
      {
        "label": "Sidebar",
        "id": "btn-sidebar",
        "onclick": "toggleSidebar()"
      },
      {
        "label": "Theme",
        "id": "btn-theme-toolbar",
        "onclick": "toggleTheme()"
      }
    ]
  },
  {
    "group": "Config",
    "color": "success",
    "row": 1,
    "type": "toggle",
    "elements": [
      {
        "label": "Highlight",
        "id": "btn-highlight",
        "onclick": "toggleHighlight()"
      },
      {
        "label": "Sync Scroll",
        "id": "btn-sync-scroll",
        "onclick": "toggleSyncScroll()"
      }
    ]
  },
  {
    "group": "Status",
    "color": "",
    "alignment": "right",
    "row": 1,
    "elements": [
      {
        "label": "Storage",
        "id": "status-storage",
        "type": "span",
        "exec": "statusStorage()"
      },
      {
        "label": "Lines",
        "id": "status-lines",
        "type": "span",
        "exec": "statusLines()"
      },
      {
        "label": "Words",
        "id": "status-words",
        "type": "span",
        "exec": "statusWords()"
      },
      {
        "label": "Saved",
        "id": "status-saved",
        "type": "span",
        "exec": "isSaved()"
      },
      {
        "label": "🗑 Delete",
        "id": "status-delete-localstorage",
        "color": "danger",
        "onclick": "deleteLocalStorage()"
      }
    ]
  },
  {
    "group": "Formatting",
    "alignment": "left",
    "row": 2,
    "groups": [
      {
        "group": "Structures",
        "color": "warning",
        "alignment": "left",
        "elements": [
          {
            "label": "``` Code",
            "onclick": "fmtBlock()"
          },
          {
            "label": "> Quote",
            "onclick": "fmtLine('> ')"
          },
          {
            "label": "— Rule",
            "onclick": "insertText('\\n---\\n')"
          },
          {
            "label": "🔗 Link",
            "onclick": "insertLink()"
          },
          {
            "label": "— UL",
            "onclick": "fmtLine('- ')"
          },
          {
            "label": "1. OL",
            "onclick": "fmtLine('1. ')"
          },
          {
            "label": "Table",
            "id": "btn-table"
          }
        ]
      },
      {
        "group": "Basic",
        "color": "warning",
        "alignment": "left",
        "elements": [
          {
            "label": "Bold",
            "onclick": "fmt('**','**')"
          },
          {
            "label": "Italic",
            "onclick": "fmt('_','_')"
          },
          {
            "label": "Strike",
            "onclick": "fmt('~~','~~')"
          },
          {
            "label": "Inline",
            "onclick": "fmt('`','`')"
          }
        ]
      },
      {
        "group": "Headers",
        "color": "warning",
        "elements": [
          {
            "label": "H1",
            "onclick": "fmtLine('# ')"
          },
          {
            "label": "H2",
            "onclick": "fmtLine('## ')"
          },
          {
            "label": "H3",
            "onclick": "fmtLine('### ')"
          }
        ]
      }
    ]
  }
]
